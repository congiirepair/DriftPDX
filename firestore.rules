rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // App sync data for a specific client project.
    // Anonymous auth is enabled for the app, so signed-in devices can
    // read and write live event state without exposing the database publicly.
    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
